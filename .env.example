# ─── Google Cloud / Vertex AI ───────────────────────────────────────────────
# Your GCP project ID (e.g. my-project-123)
GOOGLE_CLOUD_PROJECT=

# Region for Vertex AI (default: us-central1)
GOOGLE_CLOUD_REGION=us-central1

# Option A — local dev: path to a service-account JSON key file
# (Never commit the actual file — it is in .gitignore)
GOOGLE_APPLICATION_CREDENTIALS=

# Option B — Vercel / CI: paste the full service-account JSON as a single line
# Takes priority over GOOGLE_APPLICATION_CREDENTIALS if set
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─── Upstash Redis (rate limiting) ──────────────────────────────────────────
# Leave blank to disable rate limiting (graceful no-op)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
